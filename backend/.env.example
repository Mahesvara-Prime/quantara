# Copy to `.env` in this directory (never commit `.env`).
# See README.md for deployment notes.

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quantara?connect_timeout=5

# --- Auth (use a long random string in production) ---
# JWT_SECRET_KEY=

# --- CORS (comma-separated; frontend origin(s) in prod) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- SPA URL (password reset / change links in emails) ---
# PUBLIC_APP_URL=http://localhost:5173

# --- Optional: Resend for transactional email ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Quantara <onboarding@resend.dev>

# --- Seed user (python -m scripts.seed_test_user) — override in any shared environment ---
# QUANTARA_SEED_FIRST_NAME=Dev
# QUANTARA_SEED_LAST_NAME=User
# QUANTARA_SEED_EMAIL=dev@example.local
# QUANTARA_SEED_PASSWORD=ChangeMeDevOnly123!
